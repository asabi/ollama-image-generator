# Local Ollama base URL
OLLAMA_BASE_URL=http://localhost:11434

# Image-generation model installed in Ollama
# (run `ollama pull x/z-image-turbo` first)
IMAGE_MODEL=x/z-image-turbo:latest

# Default gemma model used for prompt enhancement.
# The UI lets you pick any gemma model installed locally — discovered via /api/tags.
ENHANCE_MODEL=gemma4:31b

# Where the FastAPI backend listens
IMAGE_SERVICE_HOST=127.0.0.1
IMAGE_SERVICE_PORT=8765

# Where the Vite dev server listens (used by run_local.sh and CORS allowlist)
FRONTEND_PORT=5173
